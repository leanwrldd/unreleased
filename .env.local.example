# Copy this file to .env.local and fill in your token.
# .env.local is gitignored — never committed.
#
# Paste your API auth token here to skip Discord login in local dev.
# Find it in localStorage under the key "unreleased:authToken" after logging in once.
VITE_AUTH_TOKEN=your_token_here

# Separate Supabase project used only for grouping song "versions" together
# (e.g. "She's The One (v1)" / "(v2)" / "(TV Mix)") — juicewrldapi.com has no
# concept of this, so it's tracked in its own database instead. Create a free
# project at supabase.com, run the SQL from song_versions_schema.sql (see
# lib/versionsApi.ts) in its SQL editor, then paste the Project URL and anon
# public key here (Project Settings -> API).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
