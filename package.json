{
  "name": "unreleased",
  "version": "1.7.6",
  "description": "A music player for Juice WRLD",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port 3018 --strictPort --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3018 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "latif",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.469.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.juicewrldapi.player",
    "productName": "Unreleased",
    "icon": "electron/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": ["AppImage"]
    },
    "publish": {
      "provider": "github",
      "owner": "leanwrldd",
      "repo": "unreleased"
    }
  }
}
